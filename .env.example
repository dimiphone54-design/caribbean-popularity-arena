# Application
NEXT_PUBLIC_APP_NAME="CaribbeanFreedomArena"
NEXT_PUBLIC_APP_URL="http://localhost:3004"
NEXT_PUBLIC_APP_ENV="development"

# Feature flags keep local development working without production services.
NEXT_PUBLIC_ENABLE_VOTING_WRITES="false"
# Dev preview · Front 12 LIVE slots stay open (no 3h expiry) · auto on when APP_ENV=development
NEXT_PUBLIC_ARENA_KEEP_ACTIVE_SLOTS_OPEN="true"
# Owner device auto-trust · ONLY applies when Command Center is enabled below
NEXT_PUBLIC_ARENA_PRIMARY_MASTER_AUTO="true"
# Owner master key · local .env.local only · unlock API requires Command Center enabled
ARENA_MASTER_KEY="change-me-owner-only"
# YOUR local .env.local only — owner Command Center + master bypass · keep false on public deploy
NEXT_PUBLIC_COMMAND_CENTER_ENABLED="false"
NEXT_PUBLIC_ENABLE_MEMBERSHIP_CHECKOUT="false"
NEXT_PUBLIC_ENABLE_ANALYTICS="false"

# Firebase web app credentials
NEXT_PUBLIC_FIREBASE_API_KEY="placeholder"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="placeholder"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="placeholder"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="placeholder"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="placeholder"
NEXT_PUBLIC_FIREBASE_APP_ID="placeholder"

# Payment provider — WiPay sandbox (fake keys) in dev · Fygaro live later
NEXT_PUBLIC_PAYMENT_PROVIDER="wipay"

# Fygaro Links — Variable Amount button URL from dashboard
# API docs: https://help.fygaro.com/en-us/article/fygaro-links-integration-api-h78p9y/
FYGARO_PAYMENT_BUTTON_URL="https://www.fygaro.com/en/l/your-button-id"
FYGARO_API_KEY="placeholder"
FYGARO_API_SECRET="placeholder"
FYGARO_HOOK_KEY_ID="placeholder"
FYGARO_HOOK_SECRET="placeholder"
FYGARO_DEFAULT_CURRENCY="USD"
FYGARO_JWT_TTL_SECONDS="1800"
# Return URL (set in Fygaro button Advanced Options): NEXT_PUBLIC_APP_URL/payments/fygaro/return
# Hook URL (set in Fygaro button Advanced Options):   NEXT_PUBLIC_APP_URL/api/payments/fygaro/webhook

# Agora live video · console.agora.io → Project → Configure
NEXT_PUBLIC_AGORA_APP_ID="your-agora-app-id"
AGORA_APP_CERTIFICATE="your-agora-primary-certificate"

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="placeholder"
STRIPE_SECRET_KEY="placeholder"
STRIPE_WEBHOOK_SECRET="placeholder"
STRIPE_FAN_PASS_PRICE_ID="placeholder"
STRIPE_ARENA_PLUS_PRICE_ID="placeholder"
STRIPE_CREATOR_CIRCLE_PRICE_ID="placeholder"

# WiPay Trinidad — sandbox fake keys for local preview (replace with live keys after sole trader setup)
# Merchant portal: https://tt.wipayfinancial.com/Profile#bank
# Live endpoint:   https://tt.wipayfinancial.com/plugins/payments/request
# Sandbox test:    account_number=1234567890  api_key=123  environment=sandbox
NEXT_PUBLIC_WIPAY_CHECKOUT_URL="https://tt.wipayfinancial.com/plugins/payments/request"
NEXT_PUBLIC_WIPAY_ACCOUNT_NAME="CaribbeanFreedomArena Demo"
WIPAY_ACCOUNT_ID="1234567890"
WIPAY_API_KEY="123"
WIPAY_API_SECRET="wipay-demo-secret-arena"
WIPAY_MENS_ENTRY_AMOUNT_USD="6"
WIPAY_COUNTRY_CODE="TT"
WIPAY_CURRENCY="USD"
WIPAY_ENVIRONMENT="sandbox"
WIPAY_RESPONSE_URL="http://localhost:3004/payments/wipay/return"
WIPAY_FEE_STRUCTURE="customer_pay"

# Legal placeholder bot keys for local 12-hour slot rotation
CARIBBEAN_SLOTS_BOT_API_KEY="fake_caribbean_slots_bot_key"
CARIBBEAN_SLOTS_BOT_WEBHOOK_SECRET="fake_caribbean_slots_webhook_secret"
CARIBBEAN_SLOTS_BOT_LEGAL_MODE="true"
CARIBBEAN_SLOTS_BOT_POLL_SECONDS="60"
CARIBBEAN_SLOTS_ENGINE_DATA=".data/arena-engine-state.json"
NEXT_PUBLIC_ENABLE_ARENA_ENGINE="true"

# Cloudflare placeholders
CLOUDFLARE_ACCOUNT_ID="placeholder"
CLOUDFLARE_API_TOKEN="placeholder"
CLOUDFLARE_R2_ACCESS_KEY_ID="placeholder"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="placeholder"
CLOUDFLARE_R2_BUCKET_NAME="placeholder"

# Supabase · Freedom Drive leaderboard (optional — local JSON fallback when unset)
NEXT_PUBLIC_SUPABASE_URL="https://placeholder.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="placeholder"
# Table: freedom_drive_leaderboard · see scripts/supabase/freedom-drive-leaderboard.sql

# Analytics placeholders · set NEXT_PUBLIC_ENABLE_ANALYTICS=true when pixels are live
NEXT_PUBLIC_GA_MEASUREMENT_ID="placeholder"
NEXT_PUBLIC_META_PIXEL_ID="placeholder"
NEXT_PUBLIC_TIKTOK_PIXEL_ID="placeholder"
NEXT_PUBLIC_POSTHOG_KEY="placeholder"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# Production ads · set NEXT_PUBLIC_APP_URL to your public HTTPS domain (required for OG link previews)
