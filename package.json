    "lucide-react": "^1.17.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
