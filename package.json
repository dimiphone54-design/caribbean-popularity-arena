    "start": "next start",
    "start:arena": "next start --port 3004",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out .turbo .vercel tsconfig.tsbuildinfo .eslintcache node_modules/.cache",
